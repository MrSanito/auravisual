generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  COMPLETED
}

model User {
  id String @id @default(cuid())
  name String 
  company String @default("Auravisuals")  
    passwordHash String

    email        String        @unique


  accounts     Account[]  //user can have many accounts 1 to n
  categories   Category[]  //  user can create many categories 1 to n 
  transactions Transaction[]  // user ccan have many transancation 1 to n 
  budgets      Budget[]
createdAt    DateTime      @default(now()) 
}


model Account{
  id String @id @default(cuid())
    userId    String
  user      User     @relation(fields: [userId], references: [id])
  AccountName String    
  BankName String
  openingBalance Decimal  @default(0)
  balance   Decimal  @default(0)


  lastUpdate DateTime @default(now())
  createAt   DateTime @default(now())
  isDeleted  Boolean  @default(false)



  transactions Transaction[]
  
}
model Category {
  id      String           @id @default(cuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id])

  name    String
  type    TransactionType

  transactions Transaction[]
  budgets      Budget[]
}


model Transaction {
  id          String           @id @default(cuid())

  userId      String
  user        User             @relation(fields: [userId], references: [id])

  accountId   String
  account     Account          @relation(fields: [accountId], references: [id])

  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])

  type        TransactionType

  amount      Decimal
  description String?
  isDeleted   Boolean          @default(false)
  status      TransactionStatus @default(COMPLETED)

  createdAt   DateTime @default(now())
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  limit      Decimal
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, categoryId])
}