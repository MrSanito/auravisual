generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


enum TransactionType {
  INCOME
  EXPENSE
}

model User {
  id String @id @default(cuid())
  name String 
  company String @default("Auravisuals")  
    passwordHash String

    email        String        @unique


  accounts     Account[]  //user can have many accounts 1 to n
  categories   Category[]  //  user can create many categories 1 to n 
  transactions Transaction[]  // user ccan have many transancation 1 to n 
createdAt    DateTime      @default(now()) 
}


model Account{
  id String @id @default(cuid())
    userId    String
  user      User     @relation(fields: [userId], references: [id])
  AccountName String    
  BankName String
    balance   Decimal  @default(0)


  lastUpdate DateTime @default(now())
  createAt   DateTime @default(now())



  transactions Transaction[]
  
}
model Category {
  id      String           @id @default(cuid())
  userId  String
  user    User             @relation(fields: [userId], references: [id])

  name    String
  type    TransactionType

  transactions Transaction[]
}


model Transaction {
  id          String           @id @default(cuid())

  userId      String
  user        User             @relation(fields: [userId], references: [id])

  accountId   String
  account     Account          @relation(fields: [accountId], references: [id])

  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])

  type        TransactionType

  amount      Decimal
  description String?

  createdAt   DateTime @default(now())
}